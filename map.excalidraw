      "isDeleted": false,
      "boundElements": [],
      "updated": 1772497351394,
      "link": null,
      "locked": false,
      "text": "I'm a writer, a game designer, and an artist. Find\nme in the normal online places to the east; check\nout my open source contributions and tools off of\nthe Github node to the southeast. I think and write\na lot about the human world, systems, and the\nplace they tend to interact (politics); writing on\nthese topics will be attached here soon enough.",
      "fontSize": 16.114624137383757,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "I'm a writer, a game designer, and an artist. Find me in the normal online places to the east; check out my open source contributions and tools off of the Github node to the southeast. I think and write a lot about the human world, systems, and the place they tend to interact (politics); writing on these topics will be attached here soon enough.",
      "autoResize": false,
      "lineHeight": 1.25
    },
