      "isDeleted": false,
      "boundElements": [],
      "updated": 1772497184819,
      "link": null,
      "locked": false,
      "text": "Set up practice drawing sessions\nusing your own photo library! Pick from any\nfolder on your computer, gracefully handle\nsubfolders, and randomly draw the images that\ncome up, with fully configurable pose\nand session times.",
      "fontSize": 16.114624137383757,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Set up practice drawing sessions\nusing your own photo library! Pick from any\nfolder on your computer, gracefully handle\nsubfolders, and randomly draw the images that\ncome up, with fully configurable pose\nand session times.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "7hgs2EXXpt3LzPA1r4ZNc",
      "type": "text",
      "x": -540.1849827517441,
      "y": -60.08735762244797,
      "width": 367.94896716590944,
      "height": 141.00296120210788,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
