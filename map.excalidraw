      "isDeleted": false,
      "boundElements": [],
      "updated": 1772497184819,
      "link": null,
      "locked": false,
      "text": "A narrative scripting language designed to be\ntext-based, editable, git commitable, and easily\nreadable and useable by non-technical writers,\nwithout sacrificing power or scope.",
